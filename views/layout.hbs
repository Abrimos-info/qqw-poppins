<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>{{ or title.full title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
    <meta name="description" content="{{or title.full title}} {{_ "Explora conexiones y contratos entre empresarios, políticos, empresas e instituciones públicas. Esta herramienta facilita el acceso de investigadores, periodistas y ciudadanos a varias fuentes de datos abiertos para sumar a la transparencia y rendición de cuentas." }}"/>

    <meta property="og:title" content="{{or title.full title}} " />
    <meta property="og:type" content="website" />
    <meta property="og:description" content="{{or title.full title}} {{_ "Explora conexiones y contratos entre empresarios, políticos, empresas e instituciones públicas. Esta herramienta facilita el acceso de investigadores, periodistas y ciudadanos a varias fuentes de datos abiertos para sumar a la transparencia y rendición de cuentas." }}" />
    <meta property="og:url" content="https://www.quienesquien.wiki{{share_url}}" />
    <meta property="og:image" content="https://www.quienesquien.wiki/images/qqw-card.png" />

    <link rel="canonical" content="https://www.quienesquien.wiki{{share_url}}" />
    <!-- For IE 11, Chrome, Firefox, Safari, Opera -->
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">

    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="application-name" content="QuienEsQuien.Wiki">
    <!-- Control the behavior of search engine crawling and indexing -->
    <meta name="robots" content="index,follow"><!-- All Search Engines -->
    <meta name="googlebot" content="index,follow"><!-- Google Specific -->
    <!-- CSP is now sent as HTTP header using config/csp.json -->
    <link rel='stylesheet' href='/bootstrap/css/bootstrap.min.css'>
    <link rel='stylesheet' href='/stylesheets/style.css'>
    <link rel="preload" href="/fonts/fa/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin="true">
    <link rel="preload" href="/fonts/Montserrat/Montserrat-Regular.ttf" as="font" type="font/ttf" crossorigin="true">
    <link rel="dns-prefetch" href="https://www.poderlatam.org">
    <link rel="preconnect" href="https://pagead2.googlesyndication.com">
    <meta name="referrer" content="same-origin">
    <script type="text/javascript">
      const AUTOCOMPLETE_URL = "{{autocomplete_url}}";
    </script>

    {{#if (adsense_network_code)}}
      {{#unless home}}
      <!-- Google AdSense Auto Ads -->
      <!-- Note: When client parameter is in the script URL, Auto Ads is automatically enabled -->
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{adsense_network_code}}" crossorigin="anonymous"></script>
      {{/unless}}
    {{/if}}

    {{#if (taboola_enabled)}}
    <link rel="preconnect" href="https://cdn.taboola.com">
    <script>
      window.TABOOLA_ENABLED = 'true';
      {{#if (taboola_publisher_id)}}window.TABOOLA_PUBLISHER_ID = '{{taboola_publisher_id}}';{{/if}}
    </script>
    <script defer src="/javascripts/taboola-init.js?v=1"></script>
    {{/if}}

    {{#if (adplus_enabled)}}
    <!-- Ad.Plus GPT display units (Interstitial, Anchor, Responsive) -->
    <script async src="https://securepubads.g.doubleclick.net/tag/js/gpt.js" crossorigin="anonymous"></script>
    <script>
      window.googletag = window.googletag || {cmd: []};
    </script>
    <script>
      googletag.cmd.push(function() {
        var interstitialSlot = googletag.defineOutOfPageSlot('/21849154601,23310515798/Ad.Plus-Interstitial', googletag.enums.OutOfPageFormat.INTERSTITIAL);
        if (interstitialSlot) interstitialSlot.addService(googletag.pubads());
        var anchorSlot = googletag.defineOutOfPageSlot('/21849154601,23310515798/Ad.Plus-Anchor', googletag.enums.OutOfPageFormat.BOTTOM_ANCHOR);
        anchorSlot.addService(googletag.pubads());
        var anchorSlotSmall = googletag.defineOutOfPageSlot('/21849154601,23310515798/Ad.Plus-Anchor-Small', googletag.enums.OutOfPageFormat.TOP_ANCHOR);
        anchorSlotSmall.addService(googletag.pubads());
        var responsiveads = googletag.sizeMapping()
          .addSize([0,0], [[336,280],[300,250],[250,250],[320,250],[320,100],[320,50],[300,100],[300,50]])
          .addSize([750,200], [[728,90],[336,280],[300,250],[400,300],[480,320],[320,250]])
          .addSize([975,200], [[728,90],[970,250],[336,280],[300,250],[400,300],[480,320],[320,250],[980,90],[980,120]])
          .build();
        var responsiveSlot = googletag.defineSlot('/21849154601,23310515798/Ad.Plus-AI-Responsive', [[336,280]], 'responsive-1');
        if (responsiveSlot) {
          responsiveSlot.defineSizeMapping(responsiveads).addService(googletag.pubads());
        }
        googletag.pubads().setTargeting('site', ['{{adplus_website}}']);
        googletag.pubads().enableSingleRequest();
        googletag.enableServices();
        googletag.display(interstitialSlot);
        googletag.display(anchorSlot);
        googletag.display(anchorSlotSmall);
        setInterval(function(){ googletag.pubads().refresh([anchorSlot, anchorSlotSmall]); }, 30000);
      });
    </script>
    {{/if}}

  </head>
  <body class="{{#if home}}qqw-home{{/if}}" lang="{{lang}}" style="background-color: #F7F7F7;">
    {{> header-new}}
    {{> pitrack-banner}}

    {{#if (adplus_enabled)}}
    <!-- Ad.Plus Responsive Horizontal (top placement) -->
    <div class="ad-container" style="max-width: 970px; margin-left: auto; margin-right: auto; margin-bottom: 1rem;">
      <div class="advertising-label" style="font-size: 0.875rem; color: #666; margin-bottom: 0.25rem; text-align: center;">Publicidad</div>
      <center><div id="responsive-1"></div></center>
      <script>googletag.cmd.push(function() { googletag.display('responsive-1'); });</script>
    </div>
    {{/if}}

      {{{body}}}

    {{#if (adplus_enabled)}}
    <div class="advertising-section" id="adplus-advertising-section" style="margin-top: 2rem; padding: 1rem 0; border-top: 1px solid #e0e0e0; max-width: 640px; margin-left: auto; margin-right: auto;">
      <div class="advertising-label" style="font-size: 0.875rem; color: #666; margin-bottom: 0.5rem; text-align: center;">Publicidad</div>
      <script async src="https://cdn.ad.plus/player/adplus.js"></script>
      <script data-playerPro="current">
        (function(){
          var s = document.querySelector('script[data-playerPro="current"]');
          if (s) {
            s.removeAttribute("data-playerPro");
          }
          (window.playerPro = window.playerPro || []).push({
            id: "z2I717k6zq5b",
            after: s,
            appParams: {
              "C_NETWORK_CODE": "23310515798",
              "C_WEBSITE": "{{adplus_website}}"
            }
          });
        })();
      </script>
    </div>
    {{/if}}

    {{#if (taboola_enabled)}}
    <div class="advertising-section" id="taboola-advertising-section" style="display: none; margin-top: 2rem; padding: 1rem; border-top: 1px solid #e0e0e0;">
      <div class="advertising-label" style="font-size: 0.875rem; color: #666; margin-bottom: 0.5rem; text-align: center;">Publicidad</div>
      <div id="taboola-below-article-thumbnails" style="max-width: 500px; margin: 0 auto;"></div>
    </div>
    {{/if}}

    {{> footer-new}}

    <script src="/jQuery/jquery.min.js"></script>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/scrollspy.js"></script>
    <script src="/javascripts/typeahead.bundle.min.js"></script>
    <script src="/javascripts/main.js?v=4"></script>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N8DE0W26FL"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-N8DE0W26FL');
    </script>

    <script>
      window.PITRACK_URL = 'https://sociedad.info/track';
      function track(event, location, block, alternative, action, additionalData) {
        var trackingData = {
          event: event,
          location: location,
          block: block,
          alternative: alternative,
          action: action,
          sourceid: 'qqw-poppins',
          page: window.location.pathname,
          url: window.location.href,
          title: document.title,
          user_agent: navigator.userAgent,
          referrer: document.referrer,
          screen_resolution: screen.width + 'x' + screen.height,
          viewport: window.innerWidth + 'x' + window.innerHeight,
          timestamp: new Date().toISOString()
        };
        if (additionalData && typeof additionalData === 'object') {
          Object.assign(trackingData, additionalData);
        }
        fetch(window.PITRACK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(trackingData)
        }).catch(function() {});
      }
      track('page_view', 'layout', null, null, 'load');
    </script>

  </body>
</html>
